# Copy this file to .env.local and fill in your Supabase project's values.
# Project Settings -> API in the Supabase dashboard.

# Used by the browser app (Vite exposes only VITE_-prefixed vars)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Used ONLY by scripts/seed.mjs (server-side, never shipped to the browser).
# This is the service_role key — keep it secret, never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
